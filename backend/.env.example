APP_NAME=TG Marketing System
API_PREFIX=/api

# MySQL and Redis service names are defined in docker-compose.yml.
DATABASE_URL=mysql+pymysql://tg_user:change_me@tg-marketing-mysql:3306/tg_marketing?charset=utf8mb4
REDIS_URL=redis://redis:6379/0

# Host ports exposed by docker-compose. Change these if the server already uses them.
FRONTEND_PORT=8080
BACKEND_PORT=8000
MYSQL_PORT=3306
REDIS_PORT=6379

# Telegram API credentials.
# Get them from https://my.telegram.org/apps
TELEGRAM_API_ID=0
TELEGRAM_API_HASH=change_me

# Optional global fallback proxy. Usually leave empty and manage proxies in the web UI.
TELEGRAM_PROXY_URL=

# JWT signing secret. Change this before production use.
AUTH_SECRET=change_this_to_a_random_long_string

# Runtime paths inside backend container.
SESSION_DIR=/app/telegram_sessions

# CORS origins for API access.
CORS_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080"]

HEALTH_CHECK_INTERVAL_SECONDS=60
TASK_GLOBAL_CONCURRENCY=20
TASK_SESSION_LOCK_SECONDS=300
SESSION_MAX_ACTIVE_CLIENTS=300
SESSION_STARTUP_HISTORY_SYNC=true
SESSION_HISTORY_SYNC_DAYS=2
ENABLE_TASK_QUEUE=false
